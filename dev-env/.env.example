# Dev Environment Config — copy to .env and fill in
# ⏳ PENDING: AWS credentials and Bedrock model access (configure last)

# ⏳ AWS — configure via: aws configure --profile aeonx-dev
AWS_PROFILE=aeonx-dev
AWS_REGION=ap-south-1

# ⏳ Bedrock model ID for gpt-oss-120b (confirm exact ID after enabling in Bedrock console)
BEDROCK_MODEL_ID=openai.gpt-oss-120b-v1

# Agent config
CONFIDENCE_THRESHOLD=0.75
PORT=8000

# Dev mocks — no real AWS services needed locally
DEV_MODE=true
DEV_SES_LOG=./output/emails.log
DEV_S3_DIR=./output/incidents
DEV_TICKETS_LOG=./output/tickets.log

# ManageEngine — real API (tickets will be created for real)
MANAGEENGINE_URL=https://customer.aeonx.support
MANAGEENGINE_API_KEY=DDD251A1-B6B0-4801-A83E-C9200A12DF41
